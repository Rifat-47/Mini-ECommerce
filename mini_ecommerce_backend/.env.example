SECRET_KEY=your-secret-key-here
DB_NAME=ecommerce_db
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=3306
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Email — local development uses Gmail SMTP; Render uses Resend (HTTP API).
# Set RESEND_API_KEY on Render; leave blank locally to fall back to SMTP.
RESEND_API_KEY=
# Sender address shown in delivered emails.
# Use 'onboarding@resend.dev' while testing (Resend sandbox, delivers only to your account email).
# Switch to a verified domain address for production.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Gmail SMTP — used locally when RESEND_API_KEY is blank
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ShurjoPay
# Dev/sandbox: https://sandbox.shurjopayment.com  |  Production: https://engine.shurjopayment.com
SHURJOPAY_BASE_URL=https://sandbox.shurjopayment.com
SHURJOPAY_USERNAME=your-shurjopay-username
SHURJOPAY_PASSWORD=your-shurjopay-password
# Sandbox password (public): pyyk97hu&6u6
SHURJOPAY_PREFIX=SP
SHURJOPAY_RETURN_URL=http://localhost:8000/api/payments/callback/
SHURJOPAY_CANCEL_URL=http://localhost:8000/api/payments/callback/

# Frontend base URL (for post-payment redirects)
FRONTEND_URL=http://localhost:5173

# Returns — number of days after delivery within which a return can be requested
RETURN_WINDOW_DAYS=7

# Cron — secret token for /api/internal/cron/* endpoints (used by cron-job.org)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(40))"
CRON_SECRET=your-cron-secret-here

# Cache (leave blank for development — uses in-memory cache by default)
# For production with multiple workers, use Redis:
# CACHE_BACKEND=django_redis.cache.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1
